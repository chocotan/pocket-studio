{
  "device": {
    "id": "dev_local",
    "name": "",
    "alias": "My Workstation"
  },
  "server": {},
  "claude": {
    "command": "claude",
    "args": [
      "--output-format",
      "stream-json",
      "--verbose"
    ]
  },
  "direct_acp": {
    "enabled": true,
    "agents": {
      "codex": {
        "command": "npx",
        "args": ["-y", "@agentclientprotocol/codex-acp@latest"]
      },
      "opencode": {
        "command": "opencode",
        "args": ["acp"]
      },
      "kilo": {
        "command": "kilo",
        "args": ["acp", "--pure"]
      }
    }
  },
  "workspaces": [
    {
      "id": "pocket-studio",
      "name": "pocket-studio",
      "path": "/path/to/pocket-studio"
    }
  ]
}
