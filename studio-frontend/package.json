{
  "name": "studio-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "test:clipboard-images": "node scripts/test-clipboard-images.mjs",
    "test:event-model": "node scripts/test-agent-event-model.mjs",
    "test:workspace-state-cache": "node scripts/test-workspace-state-cache.mjs",
    "test:online-terminal": "node scripts/check-online-terminal.mjs",
    "build:electron:linux": "npm run build && npm run package:electron:linux",
    "build:electron:mac": "npm run build && npm run package:electron:mac",
    "build:electron:win": "npm run build && npm run package:electron:win",
    "package:electron:linux": "electron-builder --linux AppImage",
    "package:electron:mac": "electron-builder --mac dmg",
    "package:electron:win": "electron-builder --win nsis",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:direct-terminal": "node ../scripts/e2e-direct-terminal.mjs"
  },
  "build": {
    "appId": "com.pocketstudio.app",
    "productName": "Pocket Studio",
    "directories": {
      "output": "../dist/electron"
    },
    "compression": "normal",
    "electronLanguages": [
      "en-US",
      "zh-CN"
    ],
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../dist/electron-resources/bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "dist",
        "to": "ui/dist",
        "filter": [
          "**/*"
        ]
      }
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Development",
      "icon": "../packaging/appimage/pocket-studio.svg",
      "artifactName": "PocketStudio-${version}-${arch}.AppImage"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.developer-tools",
      "artifactName": "PocketStudio-${version}-${arch}.dmg"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "../packaging/appimage/pocket-studio.ico",
      "artifactName": "PocketStudio-${version}-${arch}-setup.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@base-ui/react": "^1.5.0",
    "@eslint/js": "^10.0.1",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/outfit": "^5.2.8",
    "@lobehub/icons": "^5.10.0",
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "lucide-react": "^1.17.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.6",
    "react-arborist": "^3.8.0",
    "react-dom": "^19.2.6",
    "react-resizable-panels": "^4.11.2",
    "shadcn": "^4.8.2",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.1.5"
  }
}
